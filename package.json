{
  "name": "nexlide",
  "description": "Nexlide is a modern, lightweight, and fully customizable React carousel component built with Framer Motion for smooth animations and Tailwind CSS for flexible styling.",
  "version": "1.1.1",
  "author": {
    "name": "Nexlide Team",
    "url": "https://github.com/ERPalmer"
  },
  "license": "MIT",
  "private": false,
  "keywords": [
    "react",
    "react-carousel",
    "react-component",
    "react-slider",
    "react-ui",
    "carousel",
    "slider",
    "nextjs",
    "tailwindcss",
    "framer-motion",
    "image-carousel",
    "ui-component",
    "animation",
    "nexlide"
  ],
  "homepage": "https://nexlide.netlify.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ERPalmer/nexlide.git"
  },
  "bugs": {
    "url": "https://github.com/ERPalmer/nexlide/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "framer-motion": ">=10"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.1",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "rollup": "^4.59.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}